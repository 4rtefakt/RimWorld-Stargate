<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Goa'uld : symbiotes parasites prenant le contrôle d'un hôte humain.
       Dotés de la mémoire génétique de leurs ancêtres (compétences vastes),
       quasi immortels (Deathless), se régénérant en sarcophage. Ils se posent
       en dieux.
       NOTE: "devenir Goa'uld" via le cycle du symbiote (§4.6) viendra ensuite ;
       ici = xénotype de base, spawnable et jouable.
       Icône = placeholder vanilla (Sanguophage). -->
  <XenotypeDef>
    <defName>SG_Goauld</defName>
    <label>goa'uld</label>
    <description>Symbiotes parasites d'une intelligence redoutable qui prennent le contrôle total d'un hôte humain. Forts de la mémoire génétique accumulée par leur lignée, ils sont extrêmement compétents, arrogants et quasi immortels : tant que leur cerveau est intact, ils ne meurent pas, et ils se régénèrent dans un sarcophage. Beaucoup se font passer pour des dieux et règnent en Grands Maîtres.</description>
    <iconPath>UI/Icons/Xenotypes/Sanguophage</iconPath>
    <combatPowerFactor>1.8</combatPowerFactor>
    <factionlessGenerationWeight>0</factionlessGenerationWeight>
    <genes>
      <!-- Signature : dépendance au sarcophage + immortalité -->
      <li>SG_SarcophagusRegen</li>
      <li>Deathless</li>
      <li>Ageless</li>
      <!-- Yeux luminescents (placeholder via Eyes_Red) -->
      <li>Eyes_Red</li>
      <!-- Mémoire génétique : compétences vastes + charisme -->
      <li>Beauty_Pretty</li>
      <li>AptitudeStrong_Intellectual</li>
      <li>AptitudeStrong_Social</li>
      <li>AptitudeStrong_Melee</li>
      <li>Immunity_Strong</li>
      <li>Aggression_Aggressive</li>
    </genes>
  </XenotypeDef>

</Defs>
