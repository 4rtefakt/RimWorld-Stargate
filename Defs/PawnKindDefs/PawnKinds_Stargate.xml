<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <PawnKindDef Name="SG_PawnBase" Abstract="True">
    <race>Human</race>
    <defaultFactionDef>SG_SystemLords</defaultFactionDef>
    <invNutrition>2.55</invNutrition>
    <initialResistanceRange>15~30</initialResistanceRange>
    <initialWillRange>1~4</initialWillRange>
  </PawnKindDef>

  <!-- Guerrier Jaffa : xénotype Jaffa forcé, bâton, armure + casque serpent. -->
  <PawnKindDef ParentName="SG_PawnBase">
    <defName>SG_JaffaWarrior</defName>
    <label>guerrier jaffa</label>
    <combatPower>120</combatPower>
    <xenotypeSet>
      <xenotypeChances>
        <SG_Jaffa>999</SG_Jaffa>
      </xenotypeChances>
    </xenotypeSet>
    <useFactionXenotypes>false</useFactionXenotypes>
    <backstoryFiltersOverride>
      <li>
        <categoriesChildhood>
          <li>SG_JaffaChild</li>
        </categoriesChildhood>
        <categoriesAdulthood>
          <li>SG_JaffaAdult</li>
        </categoriesAdulthood>
      </li>
    </backstoryFiltersOverride>
    <itemQuality>Normal</itemQuality>
    <gearHealthRange>0.5~1.2</gearHealthRange>
    <weaponMoney>1200~2000</weaponMoney>
    <weaponTags>
      <li>SG_JaffaWeapon</li>
    </weaponTags>
    <apparelMoney>250~450</apparelMoney>
    <apparelRequired>
      <li>SG_JaffaArmor</li>
      <li>SG_JaffaHelmet</li>
    </apparelRequired>
    <apparelTags>
      <li>IndustrialBasic</li>
    </apparelTags>
    <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
  </PawnKindDef>

  <!-- Seigneur Goa'uld : xénotype Goa'uld forcé, zat, parure. Chef de la faction. -->
  <PawnKindDef ParentName="SG_PawnBase">
    <defName>SG_GoauldLord</defName>
    <label>seigneur goa'uld</label>
    <combatPower>180</combatPower>
    <factionLeader>true</factionLeader>
    <xenotypeSet>
      <xenotypeChances>
        <SG_Goauld>999</SG_Goauld>
      </xenotypeChances>
    </xenotypeSet>
    <useFactionXenotypes>false</useFactionXenotypes>
    <backstoryFiltersOverride>
      <li>
        <categoriesChildhood>
          <li>SG_GoauldChild</li>
        </categoriesChildhood>
        <categoriesAdulthood>
          <li>SG_GoauldAdult</li>
        </categoriesAdulthood>
      </li>
    </backstoryFiltersOverride>
    <itemQuality>Excellent</itemQuality>
    <gearHealthRange>0.9~1.3</gearHealthRange>
    <weaponMoney>750~1100</weaponMoney>
    <weaponTags>
      <li>SG_GoauldWeapon</li>
    </weaponTags>
    <apparelMoney>700~1000</apparelMoney>
    <apparelRequired>
      <li>SG_GoauldRobe</li>
    </apparelRequired>
  </PawnKindDef>

  <!-- Reine Goa'uld : pondeuse, xénotype SG_GoauldQueen forcé (genre femelle
       forcé par Harmony). Rare, trouvée en défense des colonies Goa'uld :
       à capturer vivante pour disposer d'une source de larves. Peu combative. -->
  <PawnKindDef ParentName="SG_PawnBase">
    <defName>SG_GoauldQueenKind</defName>
    <label>reine goa'uld</label>
    <combatPower>140</combatPower>
    <xenotypeSet>
      <xenotypeChances>
        <SG_GoauldQueen>999</SG_GoauldQueen>
      </xenotypeChances>
    </xenotypeSet>
    <useFactionXenotypes>false</useFactionXenotypes>
    <backstoryFiltersOverride>
      <li>
        <categoriesChildhood>
          <li>SG_GoauldChild</li>
        </categoriesChildhood>
        <categoriesAdulthood>
          <li>SG_GoauldAdult</li>
        </categoriesAdulthood>
      </li>
    </backstoryFiltersOverride>
    <itemQuality>Excellent</itemQuality>
    <gearHealthRange>0.9~1.3</gearHealthRange>
    <weaponMoney>700~1000</weaponMoney>
    <weaponTags>
      <li>SG_GoauldWeapon</li>
    </weaponTags>
    <apparelMoney>800~1100</apparelMoney>
    <apparelRequired>
      <li>SG_GoauldRobe</li>
    </apparelRequired>
  </PawnKindDef>

  <!-- Reine Tok'ra : pondeuse de symbiotes tok'ra, xénotype SG_TokraQueen forcé
       (genre femelle forcé par Harmony). Sans faction propre pour l'instant :
       apparaît via dev mode / futures quêtes Tok'ra (pas dans les raids Goa'uld). -->
  <PawnKindDef>
    <defName>SG_TokraQueenKind</defName>
    <label>reine tok'ra</label>
    <race>Human</race>
    <combatPower>120</combatPower>
    <invNutrition>2.55</invNutrition>
    <initialResistanceRange>8~16</initialResistanceRange>
    <initialWillRange>1~3</initialWillRange>
    <xenotypeSet>
      <xenotypeChances>
        <SG_TokraQueen>999</SG_TokraQueen>
      </xenotypeChances>
    </xenotypeSet>
    <useFactionXenotypes>false</useFactionXenotypes>
    <backstoryFiltersOverride>
      <li>
        <categoriesChildhood>
          <li>SG_TokraChild</li>
        </categoriesChildhood>
        <categoriesAdulthood>
          <li>SG_TokraAdult</li>
        </categoriesAdulthood>
      </li>
    </backstoryFiltersOverride>
    <itemQuality>Good</itemQuality>
    <gearHealthRange>0.8~1.2</gearHealthRange>
    <apparelMoney>400~700</apparelMoney>
    <apparelRequired>
      <li>SG_GoauldRobe</li>
    </apparelRequired>
  </PawnKindDef>

</Defs>
