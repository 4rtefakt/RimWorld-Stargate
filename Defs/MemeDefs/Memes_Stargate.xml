    <iconPath>UI/Memes/Supremacist</iconPath>
    <groupDef>Misc</groupDef>
    <impact>3</impact>
    <renderOrder>90</renderOrder>
    <generalRules>
      <rulesStrings>
        <li>memeAdjective->divin</li>
        <li>memeAdjective->serpentin</li>
        <li>memeConcept->la divinité des Goa'uld</li>
        <li>memeCreed->culte</li>
        <li>memeLeaderNoun->grand maître</li>
        <li>memeLeaderAdjective->divin</li>
        <li>memeMoralist->prêtre</li>
      </rulesStrings>
    </generalRules>
  </MemeDef>

</Defs>
